# =============================================================================
# FORTRESS V4 - GITIGNORE
# =============================================================================
# Regla: Solo código y configs versionables. Nada de datos/logs/resultados.

# =============================================================================
# SECRETS (nunca commitear)
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# =============================================================================
# RUNTIME (datos/logs/resultados - van fuera del repo)
# =============================================================================
# Si accidentalmente se crean dentro del repo, ignorarlos
data/
runs/
reports/
logs/
cache/
state/
*.db
*.sqlite
*.sqlite3

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
env/
ENV/
.venv/

# =============================================================================
# IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# TESTS
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =============================================================================
# JUPYTER
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# BACKUPS
# =============================================================================
*.bak
*.backup
*.old
