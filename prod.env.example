# Production environment — Fortress v4
# Copy to prod.env and fill with real values
# NEVER commit prod.env to git

# Coinbase API credentials
COINBASE_API_KEY="organizations/your-org-id/apiKeys/your-key-id"
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----"
COINBASE_JWT_ISSUER="cdp"

# Paths (optional — defaults to relative paths)
# FORTRESS_REPO="/opt/fortress"
# FORTRESS_RUNTIME="/opt/fortress/runtime"
# FORTRESS_SECRETS="/opt/fortress/secrets"
